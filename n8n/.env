# ================================================================
# .ENV — Bot Admisión + Infraestructura
# ================================================================
# Completar todos los valores marcados con TODO antes de levantar.
# Las variables ya configuradas se mantuvieron tal cual.
# ================================================================


# ----------------------------------------------------------------
# INFRAESTRUCTURA Y DOMINIO
# ----------------------------------------------------------------
DOMAIN_NAME=ORTquestador.com
SUBDOMAIN=n8n
SSL_EMAIL=tu-email@gmail.com
GENERIC_TIMEZONE=America/Buenos_Aires

IP_SERVER=http://localhost


# ----------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ----------------------------------------------------------------
POSTGRES_USER=adminort
POSTGRES_PASSWORD=3Qj9ac55XFX

# Nombres de las bases de datos (creadas con init-db.sql)
N8N_DB_NAME=n8n_db
EVO_DB_NAME=evolution_db

# Base de datos del bot de admisión (puede ser la misma que n8n_db
# o una separada si querés aislar los datos del bot)
BOT_DB_NAME=admision_db


# ----------------------------------------------------------------
# REDIS
# ----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

CACHE_REDIS_URI=redis://redis:6379/0
CACHE_REDIS_ENABLED=true
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# Redis REST — necesario para el batch paralelo del bot (Promise.all).
# Opción A (recomendado para producción): Upstash → https://upstash.com
#   Crear cuenta gratuita → New Database → copiar REST URL y Token
# Opción B (desarrollo local): levantar redis-stack + un proxy REST
#   o usar el paquete `ioredis` en un microservicio propio
REDIS_REST_URL=TODO_https://xxx.upstash.io
REDIS_REST_TOKEN=TODO_token_upstash_aqui


# ----------------------------------------------------------------
# EVOLUTION API
# ----------------------------------------------------------------
# Clave maestra para autenticar llamadas a la API de Evolution
EVO_API_KEY=clave_maestra_test

# Nombre exacto de la instancia de WhatsApp en Evolution
# Se ve en el panel de Evolution → Instances
EVOLUTION_INSTANCE=bot_prueba

# API key de la instancia específica (puede ser igual a EVO_API_KEY
# si usás autenticación global, o diferente si la instancia tiene su propia key)
EVOLUTION_API_KEY=clave_maestra_test

# URL interna para que Evolution se comunique con n8n dentro de Docker
N8N_INTERNAL_URL=http://localhost:5678/

WEBHOOK_GLOBAL_ENABLED=false


# ----------------------------------------------------------------
# N8N
# ----------------------------------------------------------------
# URL base que usan los workflows internos para llamarse entre sí.
# En Docker Compose el nombre del servicio es el hostname interno.
# Reemplazar "n8n" por el nombre del servicio en tu docker-compose.yml
WEBHOOK_BASE_URL=http://n8n:5678

# Las URLs exactas de los webhooks se configuran en la UI de n8n
# (Settings → Variables) DESPUÉS de importar los workflows, porque
# recién ahí se conocen los paths generados. Ver README_OPERATIVO.md.


# ----------------------------------------------------------------
# GOOGLE SHEETS
# ----------------------------------------------------------------
# ID del spreadsheet de preguntas y respuestas (Q&A del bot)
# Se obtiene de la URL: docs.google.com/spreadsheets/d/ID_AQUI/edit
SPREADSHEET_ID_QA=10gXpOlRpqatmidAUsX5n2I0xMsa9IHZjaO3FyhJ9W3U

# ID del spreadsheet de registros de admisión (donde se guardan los leads)
SPREADSHEET_ID_REGISTROS=15wo5fYtM8ltrwW8IV4Gj3I3KZsZImUXs


# ----------------------------------------------------------------
# GEMINI (Google AI Studio)
# ----------------------------------------------------------------
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=TODO_api_key_google_ai_studio


# ----------------------------------------------------------------
# NOTIFICACIONES
# ----------------------------------------------------------------
# Email del administrador que recibe alertas del bot y del health check
ADMIN_EMAIL=federico.neuman@ort.edu.ar


# ----------------------------------------------------------------
# CIRCUIT BREAKER
# ----------------------------------------------------------------
# Cantidad de fallos consecutivos de un servicio para abrir el circuito
# (bloquear nuevas llamadas y usar respuesta de fallback)
CB_THRESHOLD=5

# Segundos que tarda en resetearse el contador de fallos
CB_WINDOW_TTL=60
