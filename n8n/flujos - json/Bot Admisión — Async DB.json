      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO system_logs\n  (workflow_id, node_name, remote_jid, status, created_at)\nVALUES ('bot-admision-v4', 'async-db', $1, 'success', NOW())",
        "options": {}
      },
      "id": "85e32810-bd40-48ed-a257-10a7067de685",
